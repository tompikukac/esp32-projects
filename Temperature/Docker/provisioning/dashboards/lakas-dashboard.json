        {
          "datasource": {
            "type": "influxdb",
            "uid": "P951FEA4DE68E13C5"
          },
          "hide": false,
          "query": "low = from(bucket: \"esp32\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"environment\" and r._field == \"temperature\")\n  |> aggregateWindow(every: 1d, fn: min, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"low\" }))\n\nhigh = from(bucket: \"esp32\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"environment\" and r._field == \"temperature\")\n  |> aggregateWindow(every: 1d, fn: max, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"high\" }))\n\nopen = from(bucket: \"esp32\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"environment\" and r._field == \"temperature\")\n  |> aggregateWindow(every: 1d, fn: first, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"open\" }))\n\nclose = from(bucket: \"esp32\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"environment\" and r._field == \"temperature\")\n  |> aggregateWindow(every: 1d, fn: last, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"close\" }))\n\nunion(tables: [low, high, open, close])\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => exists r.open and exists r.high and exists r.low and exists r.close)\n  |> keep(columns: [\"_time\", \"open\", \"high\", \"low\", \"close\", \"name\"])",
          "refId": "A"
        }
      ],
      "title": "Temperature",
      "type": "candlestick"
