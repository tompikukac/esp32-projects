          "hide": false,
          "query": "data = from(bucket: \"esp32\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"environment\" and r._field == \"temperature\")\n  |> group(columns: [\"name\"]) \n\nmax_val = data |> max() |> map(fn: (r) => ({ r with stat: \"max\", _time: now() }))\nmin_val = data |> min() |> map(fn: (r) => ({ r with stat: \"min\", _time: now() }))\navg_val = data |> mean() |> map(fn: (r) => ({ r with stat: \"avg\", _time: now() }))\n\nunion(tables: [max_val, min_val, avg_val])\n  |> pivot(rowKey:[\"name\", \"_time\"], columnKey: [\"stat\"], valueColumn: \"_value\")\n  |> group()",
          "refId": "A"
        }
      ],
